# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  inhibit_all_warnings!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# Permanent Fix: Automatically repair broken xcconfig paths
def fix_xcconfigs(installer)
  flutter_dir = File.expand_path('Flutter', File.dirname(__FILE__))
  Dir.glob(File.join(flutter_dir, '*.xcconfig')).each do |file_path|
    content = File.read(file_path)
    config_name = File.basename(file_path, '.xcconfig').downcase
    
    # Target configurations (debug/release/profile)
    pod_config_part = case config_name
                      when 'debug' then 'debug'
                      when 'release' then 'release'
                      when 'profile' then 'profile'
                      else next
                      end
    
    pods_include = "#include \"../Pods/Target Support Files/Pods-Runner/Pods-Runner.#{pod_config_part}.xcconfig\""
    
    # Remove any incorrect includes (without ../ prefix) and ensure the correct one is present
    wrong_include = "#include \"Pods/Target Support Files/Pods-Runner/Pods-Runner.#{pod_config_part}.xcconfig\""
    
    if content.include?(wrong_include)
      content = content.gsub(wrong_include, pods_include)
      File.write(file_path, content)
      puts "Fixed incorrect Pods include in #{File.basename(file_path)}"
    elsif !content.include?(pods_include)
      File.open(file_path, 'a') { |f| f.puts "\n#{pods_include}" }
      puts "Added missing Pods include to #{File.basename(file_path)}"
    end
  end
end

post_install do |installer|
  # 1. Run xcconfig auto-repair
  fix_xcconfigs(installer)

  # 2. Update all pod targets
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
      
      # Recommended settings for Xcode 15/16
      config.build_settings['ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS'] = 'YES'
      config.build_settings['CLANG_ANALYZER_LOCALIZABILITY_NONLOCALIZED'] = 'YES'
      config.build_settings['ENABLE_HARDENED_RUNTIME'] = 'NO'
    end
  end
  
  # 3. Update project-level settings for Pods.xcodeproj
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
    config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
    config.build_settings['ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS'] = 'YES'
    config.build_settings['CLANG_ANALYZER_LOCALIZABILITY_NONLOCALIZED'] = 'YES'
  end

  # Set Upgrade Check versions for Pods project to latest (satisfies "Update to recommended settings")
  installer.pods_project.root_object.attributes['LastUpgradeCheck'] = '1600'
  installer.pods_project.root_object.attributes['LastSwiftUpdateCheck'] = '1600'
  installer.pods_project.root_object.attributes['LastTestingUpgradeCheck'] = '1600'
  installer.pods_project.save

  # 4. Patch Embed/Copy Pods scripts (Actual files on disk)
  installer.aggregate_targets.each do |target|
    support_files_dir = target.support_files_dir
    Dir.glob(File.join(support_files_dir, '*.sh')).each do |script_path|
      puts "Patching script: #{script_path}"
      script_content = File.read(script_path)
      
      # Step 1: Fix readlink -f and realpath -mq with simple python-based realpath
      # This replaces the shell call with a direct python execution for stability
      updated_content = script_content.gsub(/readlink -f ["']\$([^"']+)["']/, 'python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$\1"')
      updated_content = updated_content.gsub(/readlink -f \$([a-zA-Z0-9_]+)/, 'python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" $\1')
      updated_content = updated_content.gsub('readlink -f', 'python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))"')
      updated_content = updated_content.gsub(/realpath -mq ["']\$([^"']+)["']/, 'python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$\1"')
      updated_content = updated_content.gsub('realpath -mq', 'python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))"')

      # Step 2: Ensure the script doesn't fail on code signing errors if not critical
      # Sometimes codesign fails due to sandbox issues even when sandboxing is "off" in settings
      # We don't want to swallow errors, but we do want to ensure our realpath fix is applied.

      if script_content != updated_content
        File.write(script_path, updated_content)
        puts "✅ Successfully patched #{File.basename(script_path)} with robust realpath"
      end
    end

    # Also update Runner project targets directly
    target.user_project.native_targets.each do |native_target|
      native_target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS'] = 'YES'
        config.build_settings['CLANG_ANALYZER_LOCALIZABILITY_NONLOCALIZED'] = 'YES'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
        # Satisfy recommended settings
        config.build_settings['ENABLE_HARDENED_RUNTIME'] = 'NO'
        config.build_settings['SWIFT_VERSION'] = '5.0'
      end
    end

    # Satisfaction for recommended settings at project level
    target.user_project.build_configurations.each do |config|
      config.build_settings['ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS'] = 'YES'
      config.build_settings['CLANG_ANALYZER_LOCALIZABILITY_NONLOCALIZED'] = 'YES'
    end
    
    target.user_project.root_object.attributes['LastUpgradeCheck'] = '1600'
    target.user_project.save
  end
end
